{
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "%LOCALAPPDATA%/ScreenTimeTracker/logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ]
  },
  "Tracking": {
    "PollIntervalMs": 1000,
    "LimitCheckIntervalMs": 60000
  },
  "Notifications": {
    "Enabled": true,
    "QuietHoursStart": "22:00",
    "QuietHoursEnd": "08:00"
  },
  "Startup": {
    "LaunchAtStartup": false,
    "StartMinimized": false
  }
}
