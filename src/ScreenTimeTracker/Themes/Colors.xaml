<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Backgrounds -->
    <Color x:Key="WindowBackgroundColor">#F5F5F7</Color>
    <Color x:Key="CardBackgroundColor">#FFFFFF</Color>
    <Color x:Key="SidebarBackgroundColor">#E8E8ED</Color>
    <Color x:Key="SidebarHoverColor">#DCDCE0</Color>

    <!-- Text -->
    <Color x:Key="PrimaryTextColor">#1D1D1F</Color>
    <Color x:Key="SecondaryTextColor">#86868B</Color>
    <Color x:Key="TertiaryTextColor">#AEAEB2</Color>

    <!-- Accents -->
    <Color x:Key="AccentBlueColor">#007AFF</Color>
    <Color x:Key="AccentGreenColor">#34C759</Color>
    <Color x:Key="AccentOrangeColor">#FF9500</Color>
    <Color x:Key="AccentRedColor">#FF3B30</Color>
    <Color x:Key="AccentPurpleColor">#AF52DE</Color>

    <!-- Borders / Separators -->
    <Color x:Key="SeparatorColor">#D1D1D6</Color>
    <Color x:Key="BorderColor">#E5E5EA</Color>

    <!-- Progress -->
    <Color x:Key="ProgressTrackColor">#E8E8ED</Color>
    <Color x:Key="ProgressFillColor">#007AFF</Color>

    <!-- Dark mode variants -->
    <Color x:Key="DarkWindowBackgroundColor">#1C1C1E</Color>
    <Color x:Key="DarkCardBackgroundColor">#2C2C2E</Color>
    <Color x:Key="DarkSidebarBackgroundColor">#242426</Color>
    <Color x:Key="DarkPrimaryTextColor">#F5F5F7</Color>
    <Color x:Key="DarkSecondaryTextColor">#98989D</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="WindowBackground" Color="{StaticResource WindowBackgroundColor}" />
    <SolidColorBrush x:Key="CardBackground" Color="{StaticResource CardBackgroundColor}" />
    <SolidColorBrush x:Key="SidebarBackground" Color="{StaticResource SidebarBackgroundColor}" />
    <SolidColorBrush x:Key="SidebarHoverBrush" Color="{StaticResource SidebarHoverColor}" />
    <SolidColorBrush x:Key="PrimaryText" Color="{StaticResource PrimaryTextColor}" />
    <SolidColorBrush x:Key="SecondaryText" Color="{StaticResource SecondaryTextColor}" />
    <SolidColorBrush x:Key="TertiaryText" Color="{StaticResource TertiaryTextColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentBlueColor}" />
    <SolidColorBrush x:Key="AccentGreen" Color="{StaticResource AccentGreenColor}" />
    <SolidColorBrush x:Key="AccentOrange" Color="{StaticResource AccentOrangeColor}" />
    <SolidColorBrush x:Key="AccentRed" Color="{StaticResource AccentRedColor}" />
    <SolidColorBrush x:Key="SeparatorBrush" Color="{StaticResource SeparatorColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="ProgressTrack" Color="{StaticResource ProgressTrackColor}" />
    <SolidColorBrush x:Key="ProgressFill" Color="{StaticResource ProgressFillColor}" />

</ResourceDictionary>
