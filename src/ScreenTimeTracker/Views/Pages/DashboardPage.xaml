<UserControl x:Class="ScreenTimeTracker.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:ScreenTimeTracker.Views.Controls"
      xmlns:converters="clr-namespace:ScreenTimeTracker.Views.Converters">

    <UserControl.Resources>
        <converters:SecondsToTimeStringConverter x:Key="TimeStringConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24,32,32">
            <!-- 标题 -->
            <TextBlock Style="{StaticResource Title1}" Margin="0,0,0,4">
                <Run Text="今日活动" />
            </TextBlock>
            <TextBlock Text="追踪你在所有应用上的屏幕使用时间"
                       Style="{StaticResource BodySecondary}"
                       Margin="0,0,0,24" />

            <!-- 摘要卡片 -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- 总使用时间 -->
                <Border Grid.Column="0"
                        Background="{StaticResource CardBackground}"
                        CornerRadius="12"
                        Effect="{StaticResource CardShadow}"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="总使用时间"
                                   Style="{StaticResource Caption1}" />
                        <TextBlock Text="{Binding TotalTodayFormatted}"
                                   Style="{StaticResource Title2}"
                                   Margin="0,4,0,0" />
                        <TextBlock Text="今日屏幕使用时间"
                                   Style="{StaticResource Caption2}"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </Border>

                <!-- 最常用应用 -->
                <Border Grid.Column="1"
                        Background="{StaticResource CardBackground}"
                        CornerRadius="12"
                        Effect="{StaticResource CardShadow}"
                        Padding="20"
                        Margin="12,0">
                    <StackPanel>
                        <TextBlock Text="最常用应用"
                                   Style="{StaticResource Caption1}" />
                        <TextBlock Text="{Binding MostUsedAppName}"
                                   Style="{StaticResource Title2}"
                                   Margin="0,4,0,0"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="使用时间最长"
                                   Style="{StaticResource Caption2}"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </Border>

                <!-- 追踪应用数 -->
                <Border Grid.Column="2"
                        Background="{StaticResource CardBackground}"
                        CornerRadius="12"
                        Effect="{StaticResource CardShadow}"
                        Padding="20">
                    <StackPanel>
                        <TextBlock Text="追踪应用数"
                                   Style="{StaticResource Caption1}" />
                        <TextBlock Style="{StaticResource Title2}" Margin="0,4,0,0">
                            <Run Text="{Binding AppsTrackedCount}" />
                            <Run Text=" / " FontSize="18" Foreground="{StaticResource TertiaryText}" />
                            <Run Text="{Binding ActiveAppCount}" FontSize="18" Foreground="{StaticResource TertiaryText}" />
                        </TextBlock>
                        <TextBlock Text="今日 / 总计"
                                   Style="{StaticResource Caption2}"
                                   Margin="0,2,0,0" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 无数据状态 -->
            <Border Background="{StaticResource CardBackground}"
                    CornerRadius="12"
                    Effect="{StaticResource CardShadow}"
                    Padding="32"
                    Margin="0,0,0,24"
                    Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="⏱" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12" />
                    <TextBlock Text="暂无活动记录"
                               Style="{StaticResource Title3}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="开始使用你的应用，屏幕时间将自动记录。"
                               Style="{StaticResource BodySecondary}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0" />
                </StackPanel>
            </Border>

            <!-- 今日热门应用 -->
            <TextBlock Text="今日热门应用"
                       Style="{StaticResource Title3}"
                       Margin="0,0,0,12"
                       Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}}" />

            <ItemsControl ItemsSource="{Binding DailyUsageList}"
                          Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <controls:AppCard Margin="0,0,0,8" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 最近7天 -->
            <TextBlock Text="最近 7 天"
                       Style="{StaticResource Title3}"
                       Margin="0,24,0,12"
                       Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}}" />

            <Border Background="{StaticResource CardBackground}"
                    CornerRadius="12"
                    Effect="{StaticResource CardShadow}"
                    Padding="20"
                    Height="200"
                    Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}}">
                <ItemsControl ItemsSource="{Binding WeeklyData}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <UniformGrid Rows="1" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel VerticalAlignment="Bottom"
                                        HorizontalAlignment="Center">
                                <TextBlock Text="{Binding MinutesFormatted}"
                                           Style="{StaticResource Caption1}"
                                           HorizontalAlignment="Center"
                                           Margin="0,0,0,4" />
                                <Border Width="40"
                                        Height="{Binding BarHeight}"
                                        Background="{StaticResource AccentBrush}"
                                        CornerRadius="4,4,0,0"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Bottom"
                                        MinHeight="4">
                                    <Border.LayoutTransform>
                                        <ScaleTransform ScaleY="-1" />
                                    </Border.LayoutTransform>
                                </Border>
                                <TextBlock Text="{Binding DayLabel}"
                                           Style="{StaticResource Caption2}"
                                           HorizontalAlignment="Center"
                                           Margin="0,4,0,0" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <Border Height="32" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
