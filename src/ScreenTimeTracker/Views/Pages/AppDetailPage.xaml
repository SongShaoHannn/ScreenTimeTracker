<UserControl x:Class="ScreenTimeTracker.Views.Pages.AppDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:converters="clr-namespace:ScreenTimeTracker.Views.Converters">

    <UserControl.Resources>
        <converters:SecondsToTimeStringConverter x:Key="TimeStringConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
        <converters:RatioToColorConverter x:Key="RatioToColorConverter" />
        <converters:UsageToWidthConverter x:Key="UsageToWidthConverter" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,24,32,32">

            <!-- 头部 -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Width="64" Height="64"
                        CornerRadius="16"
                        Background="#F0F0F0"
                        VerticalAlignment="Top">
                    <TextBlock Text="📱"
                               FontSize="32"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <StackPanel Grid.Column="1" Margin="16,0,0,0">
                    <TextBlock Text="{Binding AppName}"
                               Style="{StaticResource Title1}" />
                    <TextBlock Text="{Binding ProcessName}"
                               Style="{StaticResource BodySecondary}" />
                    <TextBlock Text="{Binding Category}"
                               Style="{StaticResource Caption1}"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Grid>

            <!-- 今日使用情况 -->
            <Border Background="{StaticResource CardBackground}"
                    CornerRadius="12"
                    Effect="{StaticResource CardShadow}"
                    Padding="24"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="今日使用情况"
                               Style="{StaticResource Title3}"
                               Margin="0,0,0,16" />

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Height="8" Margin="0,0,0,12">
                            <Border CornerRadius="4" Background="{StaticResource ProgressTrack}" />
                            <Border CornerRadius="4"
                                    HorizontalAlignment="Left"
                                    Width="{Binding UsageRatio, Converter={StaticResource UsageToWidthConverter}, ConverterParameter=999}"
                                    Background="{Binding UsageRatio, Converter={StaticResource RatioToColorConverter}}" />
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Style="{StaticResource Title2}">
                                    <Run Text="{Binding TodayUsageFormatted}" />
                                </TextBlock>
                                <TextBlock Text="今日屏幕使用时间"
                                           Style="{StaticResource Caption1}" />
                            </StackPanel>

                            <TextBlock Grid.Column="1"
                                       Text="{Binding UsageRatioText}"
                                       Style="{StaticResource Title2}"
                                       VerticalAlignment="Center"
                                       Visibility="{Binding LimitEnabled, Converter={StaticResource BoolToVisibilityConverter}}" />
                        </Grid>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 时间限制 -->
            <Border Background="{StaticResource CardBackground}"
                    CornerRadius="12"
                    Effect="{StaticResource CardShadow}"
                    Padding="24"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="时间限制"
                               Style="{StaticResource Title3}"
                               Margin="0,0,0,16" />

                    <!-- 启用开关 -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="启用时间限制"
                                       Style="{StaticResource Headline}" />
                            <TextBlock Text="超出每日限额时提醒你"
                                       Style="{StaticResource Caption1}" />
                        </StackPanel>

                        <CheckBox Grid.Column="1"
                                  IsChecked="{Binding LimitEnabled}"
                                  Style="{StaticResource AppleToggleButton}"
                                  VerticalAlignment="Center" />
                    </Grid>

                    <StackPanel Visibility="{Binding LimitEnabled, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="每日限额"
                                   Style="{StaticResource Caption1}"
                                   Margin="0,0,0,8" />

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="小时"
                                           Style="{StaticResource Caption2}"
                                           Margin="0,0,0,4" />
                                <TextBox Text="{Binding LimitHours, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource AppleTextBox}"
                                         TextAlignment="Center"
                                         FontSize="20"
                                         Width="80" />
                            </StackPanel>

                            <TextBlock Grid.Column="1"
                                       Text=":"
                                       Style="{StaticResource Title2}"
                                       VerticalAlignment="Bottom"
                                       Margin="8,0"
                                       Padding="0,0,0,6" />

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="分钟"
                                           Style="{StaticResource Caption2}"
                                           Margin="0,0,0,4" />
                                <TextBox Text="{Binding LimitMinutesPart, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource AppleTextBox}"
                                         TextAlignment="Center"
                                         FontSize="20"
                                         Width="80" />
                            </StackPanel>
                        </Grid>

                        <Button Content="保存限制"
                                Command="{Binding SaveLimitCommand}"
                                Style="{StaticResource ApplePrimaryButton}"
                                HorizontalAlignment="Left"
                                Width="120" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 今日使用记录 -->
            <Border Background="{StaticResource CardBackground}"
                    CornerRadius="12"
                    Effect="{StaticResource CardShadow}"
                    Padding="24">
                <StackPanel>
                    <TextBlock Text="今日使用记录"
                               Style="{StaticResource Title3}"
                               Margin="0,0,0,16" />

                    <ItemsControl ItemsSource="{Binding TodaySessions}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource BorderBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding TimeRange}"
                                                       Style="{StaticResource Body}" />
                                        </StackPanel>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Duration}"
                                                   Style="{StaticResource Headline}"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="今日暂无使用记录"
                               Style="{StaticResource BodySecondary}"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,0"
                               Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <Border Height="32" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
