<UserControl x:Class="ScreenTimeTracker.Views.Controls.AppCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:ScreenTimeTracker.Views.Converters"
             Height="72">

    <UserControl.Resources>
        <converters:SecondsToTimeStringConverter x:Key="TimeStringConverter" />
        <converters:RatioToColorConverter x:Key="RatioToColorConverter" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:UsageToWidthConverter x:Key="UsageToWidthConverter" />
    </UserControl.Resources>

    <Border Background="{StaticResource CardBackground}"
            CornerRadius="12"
            Effect="{StaticResource CardShadow}"
            Cursor="Hand"
            MouseLeftButtonDown="Card_MouseLeftButtonDown">
        <Grid Margin="16,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- App Icon -->
            <Border Grid.Column="0"
                    Width="40" Height="40"
                    CornerRadius="10"
                    Background="#F0F0F0"
                    VerticalAlignment="Center">
                <TextBlock Text="📱"
                           FontSize="20"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center" />
            </Border>

            <!-- App Info -->
            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="{Binding AppName}"
                           Style="{StaticResource Headline}"
                           TextTrimming="CharacterEllipsis" />
                <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                    <TextBlock Text="{Binding TotalMinutes, Converter={StaticResource TimeStringConverter}}"
                               Style="{StaticResource Caption1}" />
                    <TextBlock Text=" 今日"
                               Style="{StaticResource Caption2}"
                               Margin="4,0,0,0" />
                </StackPanel>
            </StackPanel>

            <!-- Usage Progress -->
            <StackPanel Grid.Column="2" VerticalAlignment="Center" Width="140">
                <!-- Progress Bar -->
                <Grid Height="6">
                    <Border CornerRadius="3"
                            Background="{StaticResource ProgressTrack}" />
                    <Border CornerRadius="3"
                            HorizontalAlignment="Left"
                            Width="{Binding UsageRatio, Converter={StaticResource UsageToWidthConverter}, ConverterParameter=140}"
                            Background="{Binding UsageRatio, Converter={StaticResource RatioToColorConverter}}" />
                </Grid>
                <!-- Percentage -->
                <TextBlock Text="{Binding UsageRatioText}"
                           Style="{StaticResource Caption2}"
                           HorizontalAlignment="Right"
                           Margin="0,4,0,0"
                           Visibility="{Binding LimitMinutes, Converter={StaticResource BoolToVisibilityConverter}}" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
